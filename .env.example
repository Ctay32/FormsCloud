# Environment Variables Template
# Copier ce fichier vers .env.local et remplir les valeurs

# Supabase Configuration
# Trouvez ces valeurs dans Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Service Key (for server-side operations)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Application URL (for Vercel)
# NEXT_PUBLIC_APP_URL=https://formcloud.vercel.app

# Environment (development, staging, production)
# NODE_ENV=development
